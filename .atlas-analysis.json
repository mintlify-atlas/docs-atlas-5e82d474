  "keyFeatures": [
    "Token-efficient single proxy tool (~200 tokens vs 10k+)",
    "Lazy server lifecycle with automatic idle timeout",
    "Metadata caching for offline tool discovery",
    "Direct tool registration for frequently-used tools",
    "OAuth and bearer token authentication",
    "HTTP and stdio transport with automatic fallback",
    "Interactive management panel",
    "Import configs from Cursor, Claude Desktop, VS Code"
  ],
  "publicApiSurface": [
    "mcp({ }) - Status mode",
    "mcp({ search: '...' }) - Search tools",
    "mcp({ describe: '...' }) - Tool details",
    "mcp({ tool: '...', args: '...' }) - Call tool",
    "mcp({ connect: '...' }) - Connect server",
    "mcp({ server: '...' }) - List server tools",
    "/mcp - Interactive panel",
    "/mcp reconnect - Reconnect servers",
    "/mcp tools - List all tools",
    "/mcp-auth <server> - OAuth setup",
    "mcp.json config file",
    "directTools configuration",
    "lifecycle modes: lazy, eager, keep-alive"
  ]
}
